# Copy to .env and fill in. Never commit your real .env (gitignored).

# OpenRouter API key — routes all pilot models (Qwen3-235b by default).
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-replace-me

# Optional: bypass OpenRouter for Anthropic-direct models like
# `anthropic/claude-sonnet-4-6`. See src/mcparena/pilot/lm.py.
# ANTHROPIC_API_KEY=sk-ant-replace-me

# Optional: override the default pilot model (qwen3-235b-a22b-2507).
# Any OpenRouter slug or Anthropic-direct id is accepted.
# MCPARENA_PILOT_MODEL=openrouter/qwen/qwen3-235b-a22b-2507
