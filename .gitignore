# Vendored third-party (gitignored to keep repo small; clone on demand).
# Whole directory ignored except the .gitkeep placeholder, so flat files
# accidentally placed in third_party/ are also blocked.
third_party/*
!third_party/.gitkeep

# Secret patterns — defense in depth even when files are explicitly added
**/api_key
**/.env*
!**/.env.example
**/credentials*
**/secrets.*

# Raw planning transcripts — see Docs hygiene in plan v5.1
docs/_drafts/
